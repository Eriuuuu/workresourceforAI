# 应用配置
APP_NAME=Enterprise FullStack App     # 应用名称，用于日志、监控等显示
DEBUG=False            # 生产环境关闭调试
SECRET_KEY=your-super-secret-key-change-in-production   # JWT令牌签名密钥
ALGORITHM=HS256      # JWT加密算法
ACCESS_TOKEN_EXPIRE_MINUTES=30     # 访问令牌过期时间（分钟）

# 数据库配置
MONGODB_URL=mongodb://admin:password@mongodb:27017  # 数据库连接字符串
DATABASE_NAME=enterprise_app   

# 前端配置
VITE_API_BASE_URL=http://localhost:8000/api/v1

# 监控配置
ENABLE_METRICS=True
PROMETHEUS_MULTIPROC_DIR=/tmp

# 安全配置
ALLOWED_ORIGINS=["http://localhost:3000","http://localhost:8080"]  # CORS允许的源
RATE_LIMIT_PER_MINUTE=60  # API限流配置

# MongoDB配置
MONGO_ROOT_USERNAME=admin
MONGO_ROOT_PASSWORD=password

# Grafana配置
GRAFANA_PASSWORD=admin123